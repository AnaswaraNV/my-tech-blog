---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="group block p-6 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-indigo-300 dark:hover:border-indigo-700 bg-white dark:bg-slate-900 hover:shadow-md transition-all"
>
  <time
    datetime={date.toISOString()}
    class="text-xs text-slate-500 dark:text-slate-400 mb-2 block"
  >
    {formattedDate}
  </time>

  <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors mb-2">
    {title}
  </h2>

  <p class="text-slate-600 dark:text-slate-400 text-sm line-clamp-2 mb-4">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="px-2 py-0.5 text-xs rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
          #{tag}
        </span>
      ))}
    </div>
  )}
</a>
